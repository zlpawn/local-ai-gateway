# Local server
PORT=8787
# GATEWAY_PORT=8787
# GATEWAY_HOST=127.0.0.1

# Optional main config file. If missing, the gateway falls back to legacy
# .env + models.json settings.
GATEWAY_CONFIG_FILE=gateway.config.json

# Optional local auth. If set, clients must send this as Bearer token or x-api-key.
# GATEWAY_API_KEY=local-secret

# Volcengine Ark auth
# Optional. If empty, the gateway uses the client's Gateway API key as Ark key.
# ARK_API_KEY=your-volcengine-ark-api-key
ARK_AUTH_SCHEME=bearer

# Native Anthropic Messages endpoint for Volcengine Ark plan API.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan
# ARK_MESSAGES_URL=https://ark.cn-beijing.volces.com/api/plan/v1/messages

# OpenAI-compatible endpoint for Codex-style clients.
ARK_CODEX_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# Optional official Anthropic upstream for Claude Code mixed routing.
# Requests for unmapped real Claude model IDs are forwarded here.
OFFICIAL_ANTHROPIC_BASE_URL=https://api.anthropic.com
# OFFICIAL_ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages
# OFFICIAL_ANTHROPIC_API_KEY=your-anthropic-api-key

# Models shown by /v1/models as official Claude choices.
OFFICIAL_CLAUDE_MODELS=claude-fable-5,claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5-20251001

# Model mapping file. Client model ids are mapped to Ark model ids here.
# Legacy fallback only. Prefer gateway.config.json for new setups.
MODEL_MAP_FILE=models.json

# Optional fallback model used when a request model is not in models.json.
# ARK_MODEL=your-ark-endpoint-or-model-id

# Optional fallback model list when MODEL_MAP_FILE is missing.
# EXPOSED_MODELS=claude-sonnet

# Optional inline alias override. Left side is the client model, right side is the Ark model.
# MODEL_ALIASES=claude-sonnet=deepseek-v4-pro

# Request timeout in milliseconds.
REQUEST_TIMEOUT_MS=120000
